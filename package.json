{
  "name": "omp-ext",
  "version": "0.2.2",
  "private": true,
  "description": "Oh My Pi extension marketplace (omp-grok-build, omp-rewind, \u2026)",
  "type": "module",
  "scripts": {
    "test": "bun run test:grok && bun run test:rewind",
    "test:grok": "bun --cwd plugins/omp-grok-build test",
    "test:rewind": "bun --cwd plugins/omp-rewind run test",
    "typecheck": "bun --cwd plugins/omp-grok-build run typecheck",
    "validate": "bun scripts/validate-marketplace.ts",
    "install:all": "bun install --cwd plugins/omp-grok-build"
  }
}
